generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lieu {
  id           Int         @id @default(autoincrement())
  libelle      String
  adresse      String
  ville        String
  numero_salle String?
  evenements   Evenement[]
  representations Representation[]
  idCompagnie Int
  compagnie Compagnie @relation(fields: [idCompagnie], references: [id])
}

model Categorie {
  id         Int         @id @default(autoincrement())
  nom        String
  evenements Evenement[]
  idCompagnie Int
  compagnie Compagnie @relation(fields: [idCompagnie], references: [id])
}

model Compagnie {
  id    Int      @id @default(autoincrement())
  nom   String
  membres CompanyMember[]
  evenements Evenement[]
  categoriesEvenement Categorie[]
  lieuxEvenement Lieu[]
  spectacles Spectacle[] @relation("SpectaclesCompagnie")
  objets Objet[] @relation("ObjetsCompagnie")
}

model Evenement {
  id     Int      @id @default(autoincrement())
  nom    String
  compagnieId Int
  compagnie Compagnie @relation(fields: [compagnieId], references: [id])
  lieuId Int
  lieu   Lieu     @relation(fields: [lieuId], references: [id])
  categorieId Int
  categorie   Categorie     @relation(fields: [categorieId], references: [id])
  participants ParticipantsEvenement[]
  dateDebut DateTime
  dateFin DateTime
}


model ParticipantsEvenement {
  id     Int      @id @default(autoincrement())
  utilisateurId  Int
  utilisateur  User  @relation(fields: [utilisateurId], references: [id])
  evenementId Int
  evenement Evenement @relation(fields: [evenementId],references: [id])
}


model User {
  id            Int             @id @default(autoincrement())
  email         String          @unique
  password      String
  nom           String?
  prenom        String?
  compagnies    CompanyMember[]
  evenements    ParticipantsEvenement[]

  emailVerified DateTime?
  image         String?
}

model CompanyMember {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  compagnieId Int
  compagnie   Compagnie @relation(fields: [compagnieId], references: [id])

  droitDestruction           Boolean @default(false)
  droitModificationInfos     Boolean @default(false)
  droitGestionUtilisateurs   Boolean @default(false)
  droitAccesPlanning         Boolean @default(false)
  droitGestionPlanning       Boolean @default(false)

  @@unique([userId, compagnieId])
}
// Partie groupe Communication
enum Role {
  COMEDIEN
  TECHNICIEN
  PARTENAIRE 
}

model Contact {
  id    Int     @id @default(autoincrement())
  nom String 
  prenom String
  role    Role?
  email String? @unique
  tel String? 
  date_creation DateTime @default(now())
}
// partie groupe production

enum StatutSpectacle {
  EN_CREATION
  EN_REPETITION
  EN_TOURNEE
  ARCHIVE
}

enum TypeSpectacle {
  THEATRE
  DANSE
  MUSIQUE
  CIRQUE
  AUTRE
}

enum EtatObjet {
  NEUF
  ABIME
  CASSE
}

model CategorieObjet {
  id         Int         @id @default(autoincrement())
  nom        String      @unique
  typesObjet TypeObjet[]
}

model TypeObjet {
  id          Int            @id @default(autoincrement())
  nom         String         @unique
  image       String?
  categorieId Int
  categorie   CategorieObjet @relation(fields: [categorieId], references: [id])
  objets      Objet[]
  besoins     BesoinSpectacle[]
}

model Spectacle {
  id                     Int              @id @default(autoincrement())
  titre                  String
  dure                   Int?
  description            String?
  type                   TypeSpectacle?
  statut                 StatutSpectacle  @default(EN_CREATION)
  budget_initial         Float            @default(0)
  image                  Bytes?
  imageMimeType          String?
  dossierArtistique      Bytes?
  dossierArtistiqueName  String?
  compagnieId            Int
  compagnie              Compagnie        @relation("SpectaclesCompagnie", fields: [compagnieId], references: [id])
  ficheTechnique         FicheTechnique?
  representations        Representation[]
  besoins                BesoinSpectacle[]
}

model BesoinSpectacle {
  id              Int           @id @default(autoincrement())
  nb              Int           @default(1)
  spectacleId Int
  spectacle   Spectacle         @relation(fields: [spectacleId], references: [id], onDelete: Cascade)
  typeObjetId Int
  typeObjet   TypeObjet         @relation(fields: [typeObjetId], references: [id], onDelete: Cascade)
}

model FicheTechnique {
  id          Int       @id @default(autoincrement())
  texte       String
  pdf         Bytes?
  pdfName     String?
  spectacleId Int       @unique
  spectacle   Spectacle @relation(fields: [spectacleId], references: [id], onDelete: Cascade)
}

model Representation {
  id          Int               @id @default(autoincrement())
  date        DateTime
  spectacleId Int
  spectacle   Spectacle         @relation(fields: [spectacleId], references: [id], onDelete: Cascade)
  lieuId      Int
  lieu        Lieu              @relation(fields: [lieuId], references: [id])
  reservations ReservationObjet[]
}

model Objet {
  id            Int               @id @default(autoincrement())
  typeObjetId   Int
  typeObjet     TypeObjet         @relation(fields: [typeObjetId], references: [id])
  etat          EtatObjet         @default(NEUF)
  estDisponible Boolean           @default(true)
  compagnieId   Int
  compagnie     Compagnie         @relation("ObjetsCompagnie", fields: [compagnieId], references: [id])
  commentaire   String?
  reservations  ReservationObjet[]
}

model ReservationObjet {
  id               Int            @id @default(autoincrement())
  objetId          Int
  objet            Objet          @relation(fields: [objetId], references: [id], onDelete: Cascade)
  representationId Int
  representation   Representation @relation(fields: [representationId], references: [id], onDelete: Cascade)
}


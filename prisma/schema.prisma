generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lieu {
  id           Int         @id @default(autoincrement())
  libelle      String
  adresse      String
  ville        String
  numero_salle String?
  evenements   Evenement[]
  representations Representation[]
  idCompagnie Int
  compagnie Compagnie @relation(fields: [idCompagnie], references: [id])
}

model Categorie {
  id         Int         @id @default(autoincrement())
  nom        String
  couleur    String     @default("#000000")
  evenements Evenement[]
  idCompagnie Int
  compagnie Compagnie @relation(fields: [idCompagnie], references: [id])
}

model Compagnie {
  id    Int      @id @default(autoincrement())
  nom   String
  adresse String?
  ville   String?
  codePostal String?
  siteWeb String?
  rib     String?
  siren   String?
  rcs     String?
  formeJuridique String?
  capitalSocial  Float?
  
  membres CompanyMember[]
  evenements Evenement[]
  categoriesEvenement Categorie[]
  lieuxEvenement Lieu[]
  spectacles Spectacle[] @relation("SpectaclesCompagnie")
  objets Objet[] @relation("ObjetsCompagnie")
  operations OperationFinanciere[]
  factures Facture[]
}

model Evenement {
  id     Int      @id @default(autoincrement())
  nom    String
  compagnieId Int
  compagnie Compagnie @relation(fields: [compagnieId], references: [id])
  lieuId Int
  lieu   Lieu     @relation(fields: [lieuId], references: [id])
  categorieId Int
  categorie   Categorie     @relation(fields: [categorieId], references: [id])
  participants ParticipantsEvenement[]
  dateDebut DateTime
  dateFin DateTime
}


model ParticipantsEvenement {
  id     Int      @id @default(autoincrement())
  utilisateurId  Int
  utilisateur  User  @relation(fields: [utilisateurId], references: [id])
  evenementId Int
  evenement Evenement @relation(fields: [evenementId],references: [id])
}


model User {
  id            Int             @id @default(autoincrement())
  email         String          @unique
  password      String
  nom           String?
  prenom        String?
  compagnies    CompanyMember[]
  evenements    ParticipantsEvenement[]

  emailVerified DateTime?
  image         String?
}

model CompanyMember {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  compagnieId Int
  compagnie   Compagnie @relation(fields: [compagnieId], references: [id], onDelete: Cascade)

  droitAccesDetailsCompagnie Boolean @default(false)
  droitModificationCompagnie Boolean @default(false)
  droitSuppressionCompagnie  Boolean @default(false)
  droitAjoutMembre           Boolean @default(false)
  droitSuppressionMembre     Boolean @default(false)
  droitGestionDroitsMembres  Boolean @default(false)
  droitAccesPlanning         Boolean @default(false)
  droitGestionPlanning       Boolean @default(false)
  droitAccesAdministration   Boolean @default(false)

  cachets Cachet[]

  @@unique([userId, compagnieId])
}
// Partie groupe Communication
enum Role {
  COMEDIEN
  TECHNICIEN
  PARTENAIRE 
}

model ListeContact {
  id Int @id @default(autoincrement())
  nom String @unique
  contacts Contact[] 
}

model Contact {
  id    Int     @id @default(autoincrement())
  nom String 
  prenom String
  role    Role?
  email String? @unique
  tel String?

  notes String?
  ville String?
  lieu String?
  date_creation DateTime @default(now())
  listeContacts ListeContact[]
}

// partie groupe production

enum StatutSpectacle {
  EN_CREATION
  EN_REPETITION
  EN_TOURNEE
  ARCHIVE
}

enum TypeSpectacle {
  THEATRE
  DANSE
  MUSIQUE
  CIRQUE
  AUTRE
}

enum EtatObjet {
  NEUF
  ABIME
  CASSE
}

//partie groupe administration

enum TypeOperation {
  RECETTE
  DEPENSE
}

enum SourceOperation {
  MANUEL
  FACTURE
  CACHET
}

model CategorieObjet {
  id         Int         @id @default(autoincrement())
  nom        String      @unique
  typesObjet TypeObjet[]
}

model TypeObjet {
  id          Int            @id @default(autoincrement())
  nom         String         @unique
  image       String?
  categorieId Int
  categorie   CategorieObjet @relation(fields: [categorieId], references: [id])
  objets      Objet[]
  besoins     BesoinSpectacle[]
}

model Spectacle {
  id                     Int              @id @default(autoincrement())
  titre                  String
  dure                   Int
  description            String?
  type                   TypeSpectacle?
  statut                 StatutSpectacle  @default(EN_CREATION)
  budget_initial         Float            @default(0)
  image                  Bytes?
  imageMimeType          String?
  dossierArtistique      Bytes?
  dossierArtistiqueName  String?
  compagnieId            Int
  compagnie              Compagnie        @relation("SpectaclesCompagnie", fields: [compagnieId], references: [id])
  ficheTechnique         FicheTechnique?
  representations        Representation[]
  besoins                BesoinSpectacle[]
  cachets                Cachet[]
  operations             OperationFinanciere[]
}

model BesoinSpectacle {
  id              Int           @id @default(autoincrement())
  nb              Int           @default(1)
  spectacleId Int
  spectacle   Spectacle         @relation(fields: [spectacleId], references: [id], onDelete: Cascade)
  typeObjetId Int
  typeObjet   TypeObjet         @relation(fields: [typeObjetId], references: [id], onDelete: Cascade)
}

model FicheTechnique {
  id          Int       @id @default(autoincrement())
  texte       String
  pdf         Bytes?
  pdfName     String?
  spectacleId Int       @unique
  spectacle   Spectacle @relation(fields: [spectacleId], references: [id], onDelete: Cascade)
}

model Representation {
  id          Int               @id @default(autoincrement())
  debutResa   DateTime
  finResa     DateTime
  spectacleId Int
  spectacle   Spectacle         @relation(fields: [spectacleId], references: [id], onDelete: Cascade)
  lieuId      Int
  lieu        Lieu              @relation(fields: [lieuId], references: [id])
  reservations ReservationObjet[]
}

model Objet {
  id            Int               @id @default(autoincrement())
  typeObjetId   Int
  typeObjet     TypeObjet         @relation(fields: [typeObjetId], references: [id])
  etat          EtatObjet         @default(NEUF)
  estDisponible Boolean           @default(true)
  compagnieId   Int
  compagnie     Compagnie         @relation("ObjetsCompagnie", fields: [compagnieId], references: [id])
  commentaire   String?
  reservations  ReservationObjet[]
}

model ReservationObjet {
  id               Int            @id @default(autoincrement())
  objetId          Int
  objet            Objet          @relation(fields: [objetId], references: [id], onDelete: Cascade)
  representationId Int
  representation   Representation @relation(fields: [representationId], references: [id], onDelete: Cascade)
}

model Cachet {
  id           Int      @id @default(autoincrement())
  membreId     Int
  membre       CompanyMember  @relation(fields: [membreId], references: [id], onDelete: Cascade)
  date         DateTime @default(now())
  spectacleId  Int
  spectacle    Spectacle @relation(fields: [spectacleId], references: [id], onDelete: Cascade)
  montant      Decimal  @db.Decimal(10, 2)
  statut       StatutCachet  @default(NON_PAYE)
  note         String?
}

enum StatutCachet {
  NON_PAYE
  EN_ATTENTE_DE_PAIEMENT
  PAYE
}

model OperationFinanciere {
  id          Int             @id @default(autoincrement())
  nom         String
  montant     Float
  date        DateTime
  type        TypeOperation
  statut      String          @default("en_attente") // paye, en_attente
  source      SourceOperation @default(MANUEL)
  categorie   String?         // Ex: "Subvention", "Matériel", etc.
  fichier     String?

  // Lien implicite many-to-many avec les spectacles
  spectacles  Spectacle[]

  // Préparé pour les futures FK (branches collègues)
  factureId   Int?            // ID de la facture source (si applicable)
  cachetId    Int?            // ID du cachet source (si applicable)

  compagnieId Int
  compagnie   Compagnie       @relation(fields: [compagnieId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Facture {
  id              Int      @id @default(autoincrement())
  numero          String   @unique
  dateEmission    DateTime @default(now())
  dateEcheance    DateTime
  lieuFacturation String?

  clientNom       String
  clientAdresse   String?
  clientSiren     String?

  status          FactureStatus @default(BROUILLON)

  lignes          LigneFacture[]

  compagnieId     Int
  compagnie       Compagnie @relation(fields: [compagnieId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LigneFacture {
  id              Int      @id @default(autoincrement())
  factureId       Int
  facture         Facture  @relation(fields: [factureId], references: [id], onDelete: Cascade)
  
  designation     String
  quantite        Float    @default(1)
  prixUnitaireHT  Float
  tva             Float    @default(20.0)
  type            LigneType @default(PRESTATION)
}

enum FactureStatus {
  BROUILLON
  EMISE
  PAYEE
  ANNULEE
}

enum LigneType {
  PRESTATION
  FRAIS
  REDUCTION
}
